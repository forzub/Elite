# Repair drone debug mesh
# Coordinate convention:
# +X right
# +Y up
# -Z forward
#
# Main cube + small top/front marker cube.
# Small cube means: this side is TOP and FORWARD.

o repair_drone_body

v -0.50 -0.25 -0.50
v  0.50 -0.25 -0.50
v  0.50  0.25 -0.50
v -0.50  0.25 -0.50
v -0.50 -0.25  0.50
v  0.50 -0.25  0.50
v  0.50  0.25  0.50
v -0.50  0.25  0.50

# front face -Z
f 1 2 3
f 1 3 4

# back face +Z
f 5 8 7
f 5 7 6

# left
f 1 4 8
f 1 8 5

# right
f 2 6 7
f 2 7 3

# top
f 4 3 7
f 4 7 8

# bottom
f 1 5 6
f 1 6 2


o repair_drone_top_front_marker

v -0.18  0.25 -0.55
v  0.18  0.25 -0.55
v  0.18  0.55 -0.55
v -0.18  0.55 -0.55
v -0.18  0.25 -0.20
v  0.18  0.25 -0.20
v  0.18  0.55 -0.20
v -0.18  0.55 -0.20

# marker front -Z
f 9 10 11
f 9 11 12

# marker back +Z
f 13 16 15
f 13 15 14

# marker left
f 9 12 16
f 9 16 13

# marker right
f 10 14 15
f 10 15 11

# marker top
f 12 11 15
f 12 15 16

# marker bottom
f 9 13 14
f 9 14 10