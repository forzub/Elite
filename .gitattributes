# Default: keep text normalized in repository.
* text=auto

# Source code: force LF.
*.cpp text eol=lf
*.h text eol=lf
*.hpp text eol=lf
*.c text eol=lf
*.cmake text eol=lf
CMakeLists.txt text eol=lf

# Scripts.
*.sh text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Text/data configs.
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.glsl text eol=lf
*.vert text eol=lf
*.frag text eol=lf
*.txt text eol=lf
*.md text eol=lf

# Binary assets.
*.png binary
*.jpg binary
*.jpeg binary
*.tga binary
*.bmp binary
*.gif binary
*.webp binary
*.obj text eol=lf
*.mtl text eol=lf
*.fbx binary
*.ttf binary
*.otf binary
*.wav binary
*.mp3 binary
*.ogg binary
*.zip binary